# Cleaning and professional EDA for Cali rural vs urban
# 1) Load filtered file saved earlier
# 2) Inspect relevant columns, clean missing, create useful features, run analyses per subject, visualizations
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
import numpy as np

sns.set(style='whitegrid')

# Cargar datos (ajusta la ruta si es necesario)
df_cali = pd.read_csv('Saber_Pro_2020_1_Cali_filtered.csv', encoding='utf-8')
print(df_cali.shape)
print(df_cali.columns[:40])

# Convertir columnas de puntajes a numérico
score_cols = ['PUNT_LECTURA_CRITICA','PUNT_MATEMATICAS','PUNT_C_NATURALES',
              'PUNT_SOCIALES_CIUDADANAS','PUNT_INGLES','PUNT_GLOBAL']
for c in score_cols:
    if c in df_cali.columns:
        df_cali[c] = pd.to_numeric(df_cali[c], errors='coerce')

# Crear area_simple a partir de COLE_AREA_UBICACION
df_cali['area_simple'] = df_cali['COLE_AREA_UBICACION'].str.strip().str.capitalize()

# Filtrar solo Urbano y Rural, y eliminar filas sin PUNT_GLOBAL
before = len(df_cali)
df_cali = df_cali[df_cali['area_simple'].isin(['Urbano','Rural'])]
df_cali = df_cali.dropna(subset=['PUNT_GLOBAL'])
after = len(df_cali)
print(f'Filas eliminadas: {before-after}')

# Crear variables socioeconómicas útiles
df_cali['estrato'] = df_cali['FAMI_ESTRATOVIVIENDA'].astype(str).str.extract(r'(\d+)').astype(float)
df_cali['tiene_internet'] = df_cali['FAMI_TIENEINTERNET'].str.contains('Si', case=False, na=False)

# Guardar dataset limpio
df_cali.to_csv('Saber_Pro_2020_1_Cali_cleaned.csv', index=False)
print('Archivo limpio guardado.')

# Estadísticas descriptivas por área
group_stats = df_cali.groupby('area_simple')[score_cols].agg(['count','mean','median','std']).transpose()
print(group_stats)

# Generar boxplots para cada materia
for col in score_cols:
    plt.figure(figsize=(8,5))
    sns.boxplot(x='area_simple', y=col, data=df_cali)
    plt.title(f'Distribución de {col} por área (Cali)')
    plt.tight_layout()
    plt.savefig(f'{col}_by_area.png')
    plt.show()

# Generar gráficos de densidad para cada materia
plt.figure(figsize=(8,5))
for area in ['Urbano','Rural']:
    sns.kdeplot(df_cali[df_cali['area_simple']==area]['PUNT_GLOBAL'].dropna(), label=area)
plt.title('Densidad PUNT_GLOBAL por área')
plt.legend()
plt.tight_layout()
plt.savefig('PUNT_GLOBAL_density_by_area.png')
plt.show()

# Pruebas t por materia y tamaño del efecto (d de Cohen)
results = []
for col in score_cols:
    urb = df_cali[df_cali['area_simple']=='Urbano'][col].dropna()
    rur = df_cali[df_cali['area_simple']=='Rural'][col].dropna()
    if len(urb)>1 and len(rur)>1:
        t, p = stats.ttest_ind(urb, rur, equal_var=False)
        # d de Cohen
        d = (urb.mean() - rur.mean()) / (((urb.std()**2 + rur.std()**2)/2)**0.5)
        results.append((col, len(urb), len(rur), urb.mean(), rur.mean(), t, p, d))

res_df = pd.DataFrame(results, columns=['variable','n_urb','n_rur','mean_urb','mean_rur','tstat','pvalue','cohen_d'])
print(res_df)

# Guardar resultados de pruebas
res_df.to_csv('subject_tests_simple.csv', index=False)

# Mostrar colegios top y bottom (con al menos 5 estudiantes)
school = df_cali.groupby(['COLE_NOMBRE_ESTABLECIMIENTO','area_simple'])['PUNT_GLOBAL'].agg(['count','mean']).reset_index()
school = school[school['count']>=5]
school_sorted = school.sort_values('mean', ascending=False)
print('Top 10 colegios (>=5 estudiantes):')
print(school_sorted.head(10))
print('Bottom 10 colegios (>=5 estudiantes):')
print(school_sorted.tail(10))

# Guardar gráfico de media con IC 95% (media simple)
grouped = df_cali.groupby('area_simple')['PUNT_GLOBAL'].agg(['mean','count','std']).reset_index()
grouped['se'] = grouped['std'] / np.sqrt(grouped['count'])
grouped['ci95'] = 1.96 * grouped['se']
plt.figure(figsize=(6,4))
plt.bar(grouped['area_simple'], grouped['mean'], yerr=grouped['ci95'], capsize=5)
plt.ylabel('Media PUNT_GLOBAL')
plt.title('Media de PUNT_GLOBAL por área con IC 95% (media simple)')
plt.tight_layout()
plt.savefig('mean_global_by_area_simple.png')
plt.show()
